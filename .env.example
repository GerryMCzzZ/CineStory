# CineStory 环境变量配置示例
# 复制此文件为 .env 并填入实际的 API 密钥

# ============================================
# 视频生成 API 配置
# ============================================

# Runway ML (https://runwayml.com/)
RUNWAY_API_KEY=your_runway_api_key_here
RUNWAY_BASE_URL=https://api.dev.runwayml.com/v1

# Pika Labs (https://pika.art/)
PIKA_API_KEY=your_pika_api_key_here
PIKA_BASE_URL=https://api.pika.art/v1

# Luma AI (https://lumalabs.ai/)
LUMA_API_KEY=your_luma_api_key_here
LUMA_BASE_URL=https://api.lumalabs.ai

# 可灵 AI (https://klingai.com/)
KLING_API_KEY=your_kling_api_key_here

# ============================================
# LLM API 配置
# ============================================

# OpenAI (https://openai.com/)
LLM_API_KEY=your_openai_api_key_here

# 或者使用其他 LLM 提供商
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4

# ============================================
# 数据库配置
# ============================================

MYSQL_ROOT_PASSWORD=cinestory123
MYSQL_DATABASE=cinestory
MYSQL_USER=cinestory
MYSQL_PASSWORD=cinestory123

# ============================================
# MinIO 配置
# ============================================

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ============================================
# Redis 配置
# ============================================

REDIS_PASSWORD=

# ============================================
# Docker 环境变量
# ============================================

SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/cinestory?useUnicode=true&characterEncoding=utf8mb4&serverTimezone=Asia/Shanghai
SPRING_DATASOURCE_USERNAME=cinestory
SPRING_DATASOURCE_PASSWORD=cinestory123
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

