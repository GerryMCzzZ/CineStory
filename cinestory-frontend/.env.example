# CineStory Frontend 环境变量配置模板
# 复制此文件为 .env.local 并填写实际值

# ===========================================
# API 配置
# ===========================================

# 后端 API 地址
VITE_API_HOST=localhost:8080
VITE_API_BASE_URL=http://localhost:8080/api

# WebSocket 地址
VITE_WS_HOST=localhost:8080
VITE_WS_BASE_URL=ws://localhost:8080/api/ws

# ===========================================
# 第三方服务配置
# ===========================================

# 视频播放器配置
VITE_VIDEOJS_THEME=city

# ===========================================
# 功能开关
# ===========================================

# 启用 WebSocket 实时进度
VITE_ENABLE_WEBSOCKET=true

# 启用调试模式
VITE_DEBUG=false

# ===========================================
# 开发环境配置
# ===========================================

# 开发服务器端口
VITE_DEV_PORT=5173

# 是否自动打开浏览器
VITE_DEV_OPEN=true
