<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cinestory.mapper.StyleTemplateMapper">

    <select id="selectAvailableForUser" resultType="com.cinestory.model.entity.StyleTemplate">
        SELECT * FROM style_templates
        WHERE is_system = 1 OR user_id = #{userId}
    </select>

</mapper>
