<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cinestory.mapper.UserMapper">

    <select id="selectByActiveApiKey" resultType="com.cinestory.model.entity.User">
        SELECT * FROM users
        WHERE api_key = #{apiKey} AND api_key_enabled = 1
    </select>

    <select id="selectUsersNeedingQuotaReset" resultType="com.cinestory.model.entity.User">
        SELECT * FROM users
        WHERE quota_reset_date &lt;= #{now} AND quota_used > 0
    </select>

</mapper>
