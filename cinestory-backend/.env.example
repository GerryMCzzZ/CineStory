# CineStory Backend 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ===========================================
# 数据库配置
# ===========================================
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/cinestory?useUnicode=true&characterEncoding=utf8mb4&serverTimezone=Asia/Shanghai
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_password_here

# ===========================================
# Redis 配置
# ===========================================
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=

# ===========================================
# JWT 配置
# ===========================================
JWT_SECRET=your_very_long_and_secure_secret_key_at_least_256_bits
JWT_ACCESS_TOKEN_EXPIRATION=86400000
JWT_REFRESH_TOKEN_EXPIRATION=604800000

# ===========================================
# 视频生成 API 配置
# ===========================================

# Runway ML API
RUNWAY_API_KEY=your_runway_api_key_here
RUNWAY_BASE_URL=https://api.dev.runwayml.com/v1

# Pika Labs API
PIKA_API_KEY=your_pika_api_key_here
PIKA_BASE_URL=https://api.pika.art/v1

# Luma AI API
LUMA_API_KEY=your_luma_api_key_here
LUMA_BASE_URL=https://api.lumalabs.ai

# ===========================================
# LLM 配置 (可选)
# ===========================================
LLM_ENABLED=false
LLM_API_KEY=your_openai_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4

# 如使用国内 LLM 服务，修改 BASE_URL 即可，例如：
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-max

# ===========================================
# MinIO 对象存储配置
# ===========================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=cinestory

# ===========================================
# 文件存储配置
# ===========================================
FILE_UPLOAD_PATH=./storage/uploads
VIDEO_OUTPUT_PATH=./storage/output
VIDEO_INTRO_PATH=./storage/assets/intro.mp4
VIDEO_OUTRO_PATH=./storage/assets/outro.mp4

# ===========================================
# FFmpeg 配置
# ===========================================
FFMPEG_PATH=ffmpeg

# ===========================================
# WebSocket 配置
# ===========================================
WEBSOCKET_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ===========================================
# 服务器配置
# ===========================================
SERVER_PORT=8080
SERVER_CONTEXT_PATH=/api

# ===========================================
# 日志配置
# ===========================================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_CINESTORY=DEBUG
