# ============================================
# CineStory - .gitignore
# ============================================

# ============================================
# 操作系统文件
# ============================================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.directory
.Trash-*

# ============================================
# IDE / 编辑器
# ============================================
# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr
out/
.idea_modules/

# Visual Studio Code
.vscode/
*.code-workspace

# Eclipse
.project
.classpath
.settings/
.metadata
bin/
tmp/
*.tmp
*.bak
*.swp
*~.nib
local.properties
.loadpath

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# ============================================
# Java / Maven / Spring Boot
# ============================================
target/
*.class
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar
.mvn/
mvnw
mvnw.cmd

# Spring Boot
spring-boot-*.log
spring.log
application-*.log

# ============================================
# Node.js / 前端
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# 构建产物
dist/
dist-ssr/
build/
.output/

# 依赖锁定
package-lock.json
yarn.lock
pnpm-lock.yaml

# 缓存
.cache/
.parcel-cache/
.vite/
.nuxt/
.next/

# 环境变量
.env
.env.local
.env.*.local

# ============================================
# Python (如果有)
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# ============================================
# Docker
# ============================================
*.log

# ============================================
# 日志文件
# ============================================
logs/
*.log
*.log.*

# ============================================
# 临时文件
# ============================================
*.tmp
*.temp
*.swp
*.swo
*~
.lock

# ============================================
# 测试覆盖率
# ============================================
coverage/
*.lcov
.nyc_output/
coverage.xml
*.cover

# ============================================
# 视频和媒体文件
# ============================================
*.mp4
*.avi
*.mov
*.mkv
*.flv
*.wmv
*.mp3
*.wav
*.flac
*.aac

# 视频生成中间文件
cinestory-backend/src/main/resources/videos/
cinestory-backend/src/main/resources/temp/
output/
*.output

# ============================================
# 数据库
# ============================================
*.db
*.sqlite
*.sqlite3

# ============================================
# MinIO / 对象存储
# ============================================
minio-data/
.minio/

# ============================================
# 项目特定
# ============================================
# 记忆系统的临时文件
.memory/tmp/

# API 密钥（已提供 .env.example）
.env
*.key
*.pem
secrets/

# ============================================
# 其他
# ============================================
favicon.ico
sitemap.xml
robots.txt
